# =============================================================================

import os
from pathlib import Path

# -----------------------------------------------------------------------------
# Paths
# -----------------------------------------------------------------------------

ROOT = Path(__file__).parent

PROBLEMS_DIR = ROOT / "data" / "problems"
GENERATIONS_DIR = ROOT / "data" / "generations"
EXECUTION_RESULTS_DIR = ROOT / "data" / "execution"
REPAIRS_DIR = ROOT / "data" / "repairs"
ANALYSIS_DIR = ROOT / "data" / "analysis"
MIGRATION_DIR = ROOT / "data" / "migration_notes"

ANCHORED_FILE = PROBLEMS_DIR / "prompts_anchored.json"


# -----------------------------------------------------------------------------
# Benchmark Settings
# -----------------------------------------------------------------------------

TEMPERATURE = 0.8
MAX_TOKENS = 1024
K_SAMPLES = 3

# Execution timeout per snippet in seconds.
EXECUTION_TIMEOUT = 30


# -----------------------------------------------------------------------------
# Qiskit Versions
# -----------------------------------------------------------------------------

QISKIT_VERSIONS = {
    "v0": {
        "anchor_prefix": "Using Qiskit v0.43, ",
        "conda_env": "qiskit-v0",
    },
    "v1": {
        "anchor_prefix": "Using Qiskit v1.3, ",
        "conda_env": "qiskit-v1",
    },
    "v2": {
        "anchor_prefix": "Using Qiskit v2.0, ",
        "conda_env": "qiskit-v2",
    },
}


